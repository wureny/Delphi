{
  "name": "delphi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "npm run start:runtime",
    "start:runtime": "node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "neo4j:bootstrap": "node --env-file-if-exists=.env --import tsx ./scripts/bootstrap-research-graph.ts",
    "check:research-graph": "node --env-file-if-exists=.env --import tsx ./src/research-graph/index.ts",
    "neo4j:smoke-write": "node --env-file-if-exists=.env --import tsx ./scripts/run-neo4j-smoke-write.ts",
    "neo4j:verify": "node --env-file-if-exists=.env --import tsx ./scripts/check-neo4j-connectivity.ts",
    "openbb:smoke": "node --env-file-if-exists=.env --import tsx ./scripts/run-openbb-adapter-smoke.ts",
    "data:artifacts:read": "tsx ./scripts/read-persisted-artifacts.ts",
    "runtime:demo": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:demo:neo4j": "RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:demo:openai": "RUNTIME_EXECUTION_MODE=openai node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:demo:openai:neo4j": "RUNTIME_EXECUTION_MODE=openai RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:demo:openbb": "RUNTIME_DATA_MODE=openbb node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:demo:openbb:neo4j": "RUNTIME_DATA_MODE=openbb RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-demo.ts",
    "runtime:serve": "node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:serve:neo4j": "RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:serve:openai": "RUNTIME_EXECUTION_MODE=openai node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:serve:openai:neo4j": "RUNTIME_EXECUTION_MODE=openai RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:serve:openbb": "RUNTIME_DATA_MODE=openbb node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:serve:openbb:neo4j": "RUNTIME_DATA_MODE=openbb RUNTIME_GRAPH_MODE=neo4j node --env-file-if-exists=.env --import tsx ./scripts/serve-runtime-api.ts",
    "runtime:smoke": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-smoke.ts",
    "runtime:smoke:gold": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-smoke.ts gold",
    "runtime:smoke:openbb-degraded": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-smoke.ts openbb-degraded",
    "runtime:smoke:graph-degraded": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-smoke.ts graph-degraded",
    "runtime:smoke:terminal": "node --env-file-if-exists=.env --import tsx ./scripts/run-runtime-smoke.ts terminal",
    "frontend:demo:record": "node --env-file-if-exists=.env --import tsx ./scripts/export-runtime-demo-fixture.ts",
    "frontend:config": "node --import tsx ./scripts/build-frontend-runtime-config.ts",
    "frontend:build": "npm run frontend:config && tsc -p ./tsconfig.frontend.json",
    "frontend:serve": "node --env-file-if-exists=.env --import tsx ./scripts/serve-frontend.ts",
    "dev:live": "node --env-file-if-exists=.env --import tsx ./scripts/dev-live.ts",
    "frontend:typecheck": "tsc -p ./tsconfig.frontend.json --noEmit",
    "typecheck": "tsc --noEmit && npm run frontend:typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "neo4j-driver": "^6.0.1",
    "tsx": "^4.21.0"
  }
}
